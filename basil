#!/bin/bash
set -e

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# --- Check dependencies ---
check_deps() {
    local missing=()
    for cmd in docker jq; do
        if ! command -v "$cmd" &>/dev/null; then
            missing+=("$cmd")
        fi
    done
    if [ ${#missing[@]} -gt 0 ]; then
        echo -e "${RED}Missing required commands:${NC}"
        for cmd in "${missing[@]}"; do
            echo "  - $cmd"
        done
        echo ""
        echo "Please install them and try again."
        exit 1
    fi
}
check_deps

IMAGE_NAME="claude-code-runner"
CONTAINER_PREFIX="claude"

# Get the directory where basil is installed (resolve symlinks)
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
    SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ $SCRIPT_PATH != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"


# --- Helper: Get container name from project path ---
get_container_name() {
    local project_dir="$1"
    local basename=$(basename "$project_dir")
    echo "${CONTAINER_PREFIX}-${basename}"
}

# --- Helper: Check if port is available ---
is_port_free() {
    local port="$1"
    ! ss -tuln 2>/dev/null | grep -q ":${port} " && \
    ! docker ps --format '{{.Ports}}' 2>/dev/null | grep -q "0.0.0.0:${port}->"
}

# --- Helper: Get claude dir (fallback to ~/.local/basil if project not writable) ---
get_claude_dir() {
    local project_dir="$1"

    if [ -w "$project_dir" ]; then
        echo "$project_dir/.basil"
    else
        # /usr/local/bin → ~/.local/basil/usr_local_bin
        local encoded=$(echo "$project_dir" | sed 's|^/||; s|/|_|g')
        echo "$HOME/.local/basil/$encoded"
    fi
}

# --- Helper: Get port for project (hash-based, range 8100-8199, auto-increment if busy) ---
get_project_port() {
    local project_dir="$1"
    local basename=$(basename "$project_dir")
    # Simple hash: sum of ASCII values mod 100 + 8100
    local hash=0
    for (( i=0; i<${#basename}; i++ )); do
        hash=$((hash + $(printf '%d' "'${basename:$i:1}")))
    done
    local base_port=$((8100 + hash % 100))
    local port=$base_port
    local max_tries=100

    # Find first available port
    while ! is_port_free "$port" && [ $((port - base_port)) -lt $max_tries ]; do
        port=$((port + 1))
        # Wrap around if needed
        if [ $port -ge 8200 ]; then
            port=8100
        fi
    done
    echo $port
}

# --- Build ---
build() {
    echo -e "${GREEN}Building Docker image...${NC}"
    docker build -t "$IMAGE_NAME" "$SCRIPT_DIR"
    echo -e "${GREEN}✓ Image built${NC}"
}

# --- Init (create .basil in project or fallback location) ---
init_project() {
    local PROJECT_DIR="$1"
    local CLAUDE_DIR=$(get_claude_dir "$PROJECT_DIR")

    # Check source credentials exist
    if [ ! -f "$HOME/.claude/.credentials.json" ]; then
        echo -e "${RED}Error: ~/.claude/.credentials.json not found${NC}"
        echo "Please login to Claude Code first: claude login"
        exit 1
    fi

    echo -e "${GREEN}Initializing...${NC}"

    # Create parent directory if using fallback location
    mkdir -p "$(dirname "$CLAUDE_DIR")"

    # Create .basil directory
    rm -rf "$CLAUDE_DIR"

    # Copy entire ~/.claude folder (following symlinks)
    \cp -rL "$HOME/.claude" "$CLAUDE_DIR"

    # Copy ~/.claude.json (separate file with onboarding state, theme, etc.)
    if [ -f "$HOME/.claude.json" ]; then
        \cp -L "$HOME/.claude.json" "$CLAUDE_DIR/.claude.json"
    fi

    # Strip hooks from settings (they reference host paths)
    if [ -f "$CLAUDE_DIR/settings.json" ]; then
        jq 'del(.hooks)' "$CLAUDE_DIR/settings.json" > "$CLAUDE_DIR/settings.json.tmp"
        mv "$CLAUDE_DIR/settings.json.tmp" "$CLAUDE_DIR/settings.json"
    fi
    if [ -f "$CLAUDE_DIR/settings.local.json" ]; then
        jq 'del(.hooks)' "$CLAUDE_DIR/settings.local.json" > "$CLAUDE_DIR/settings.local.json.tmp"
        mv "$CLAUDE_DIR/settings.local.json.tmp" "$CLAUDE_DIR/settings.local.json"
    fi

    # Update .gitignore only if project is writable
    if [ -w "$PROJECT_DIR" ]; then
        local GITIGNORE="$PROJECT_DIR/.gitignore"
        if [ -f "$GITIGNORE" ]; then
            if ! grep -q "^\.basil/$" "$GITIGNORE" && ! grep -q "^\.basil$" "$GITIGNORE"; then
                echo ".basil/" >> "$GITIGNORE"
            fi
        else
            echo ".basil/" > "$GITIGNORE"
        fi
    fi

    echo -e "${GREEN}✓ State dir: $CLAUDE_DIR${NC}"
}

# --- Start container + API server ---
start() {
    local PROJECT_DIR=""
    local SERVE_UI=0
    local PORT=""

    # Parse flags and path
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --ui)
                SERVE_UI=1
                shift
                ;;
            --port)
                PORT="$2"
                shift 2
                ;;
            --port=*)
                PORT="${1#*=}"
                shift
                ;;
            -*)
                echo -e "${RED}Unknown option: $1${NC}"
                exit 1
                ;;
            *)
                # Positional argument = path
                PROJECT_DIR="$1"
                shift
                ;;
        esac
    done

    # Default to current directory
    if [ -z "$PROJECT_DIR" ]; then
        PROJECT_DIR="$PWD"
    fi

    # Make path absolute
    PROJECT_DIR="$(cd "$PROJECT_DIR" 2>/dev/null && pwd)" || {
        echo -e "${RED}Error: Directory not found: $1${NC}"
        exit 1
    }

    local CLAUDE_DIR=$(get_claude_dir "$PROJECT_DIR")
    local CONTAINER_NAME=$(get_container_name "$PROJECT_DIR")

    # Default port based on project name
    if [ -z "$PORT" ]; then
        PORT=$(get_project_port "$PROJECT_DIR")
    fi

    # Auto-init if needed
    if [ ! -d "$CLAUDE_DIR" ] || [ ! -f "$CLAUDE_DIR/.credentials.json" ]; then
        init_project "$PROJECT_DIR"
    fi

    # Check if container already running
    if docker ps --format '{{.Names}}' | grep -q "^${CONTAINER_NAME}$"; then
        echo -e "${YELLOW}Already running${NC}"
        echo "Use 'basil stop' first, or open http://localhost:${PORT}"
        exit 0
    fi

    # Remove any stopped container with same name
    docker rm -f "$CONTAINER_NAME" 2>/dev/null || true

    # Build mount arguments
    local MOUNTS=(
        -v "$PROJECT_DIR:/workspace"
        -v "$CLAUDE_DIR:/home/claude/.claude"
    )
    if [ -f "$CLAUDE_DIR/.claude.json" ]; then
        MOUNTS+=(-v "$CLAUDE_DIR/.claude.json:/home/claude/.claude.json")
    fi

    if [ "$SERVE_UI" = "1" ]; then
        echo -e "${GREEN}Basil on http://localhost:${PORT}${NC}"
    else
        echo -e "${GREEN}Basil API on http://localhost:${PORT}${NC}"
        echo "  (--ui for web interface)"
    fi
    echo "  Ctrl+C to stop"
    echo ""

    # Run container with server directly (foreground)
    local PROJECT_NAME=$(basename "$PROJECT_DIR")
    # Use -t only if we have a TTY
    local TTY_FLAG=""
    if [ -t 0 ]; then
        TTY_FLAG="-t"
    fi
    docker run --rm -i $TTY_FLAG --name "$CONTAINER_NAME" \
        --user "$(id -u):$(id -g)" \
        -p ${PORT}:${PORT} \
        -w /workspace \
        -e HOME=/home/claude \
        -e CI=1 \
        -e HOST=0.0.0.0 \
        -e PORT=${PORT} \
        -e SERVE_UI=$SERVE_UI \
        -e PROJECT_NAME="$PROJECT_NAME" \
        -e PROJECT_PATH="$PROJECT_DIR" \
        -e PYTHONPATH=/opt/basil \
        "${MOUNTS[@]}" \
        "$IMAGE_NAME" \
        python3 -m src.main
}

# --- Stop ---
stop() {
    local PROJECT_DIR="${1:-$PWD}"

    # Make path absolute
    PROJECT_DIR="$(cd "$PROJECT_DIR" 2>/dev/null && pwd)" || {
        echo -e "${RED}Error: Directory not found: $1${NC}"
        exit 1
    }

    local CONTAINER_NAME=$(get_container_name "$PROJECT_DIR")

    if docker ps --format '{{.Names}}' | grep -q "^${CONTAINER_NAME}$"; then
        docker stop "$CONTAINER_NAME" >/dev/null 2>&1
        echo -e "${GREEN}✓ Stopped${NC}"
    else
        echo "Not running"
    fi
}

# --- Main ---
case "${1:-help}" in
    build)
        build
        ;;
    start)
        shift
        start "$@"
        ;;
    stop)
        shift
        stop "$@"
        ;;
    *)
        echo "Basil - Claude Code in Docker"
        echo ""
        echo "  basil build                          Build image (once)"
        echo "  basil start [options] [path]         Start server"
        echo "  basil stop [path]                    Stop server"
        echo ""
        echo "Options:"
        echo "  --ui         Enable web interface"
        echo "  --port N     Use specific port (default: auto 8100-8199)"
        echo ""
        echo "Path defaults to current directory if not specified"
        ;;
esac
