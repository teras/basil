#!/bin/bash
# Basil CLI - Simple client for testing

BASIL_URL="${BASIL_URL:-http://localhost:8765}"
SESSION_FILE="$HOME/.basil/current_session"

mkdir -p "$HOME/.basil"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

show_help() {
    echo "Basil CLI - Chat with Claude Code"
    echo ""
    echo "Usage: basil-cli <command> [args]"
    echo ""
    echo "Commands:"
    echo "  new [dir]      Create new session (default: current dir)"
    echo "  list           List all sessions"
    echo "  use <id>       Switch to session"
    echo "  status         Show current session"
    echo "  send <text>    Send message and get response"
    echo "  chat           Interactive chat mode"
    echo "  stop           Stop current operation"
    echo ""
    echo "Environment:"
    echo "  BASIL_URL      Server URL (default: http://localhost:8765)"
}

get_session() {
    if [ -f "$SESSION_FILE" ]; then
        cat "$SESSION_FILE"
    else
        echo ""
    fi
}

cmd_new() {
    local dir="${1:-$(pwd)}"
    local resp=$(curl -s -X POST "$BASIL_URL/session/new" \
        -H "Content-Type: application/json" \
        -d "{\"working_dir\": \"$dir\"}")

    local sid=$(echo "$resp" | python3 -c "import sys,json; print(json.load(sys.stdin)['session_id'])" 2>/dev/null)

    if [ -n "$sid" ]; then
        echo "$sid" > "$SESSION_FILE"
        echo -e "${GREEN}Created session: $sid${NC}"
        echo -e "Working dir: $dir"
    else
        echo -e "${RED}Failed to create session${NC}"
        echo "$resp"
    fi
}

cmd_list() {
    curl -s "$BASIL_URL/session/list" | python3 -c "
import sys, json
data = json.load(sys.stdin)
for s in data.get('sessions', []):
    print(f\"{s['session_id']}  {s['working_dir']}  {s.get('created_at', '')[:16]}\")
"
}

cmd_use() {
    local sid="$1"
    if [ -z "$sid" ]; then
        echo "Usage: basil-cli use <session_id>"
        return 1
    fi
    echo "$sid" > "$SESSION_FILE"
    echo -e "${GREEN}Switched to session: $sid${NC}"
}

cmd_status() {
    local sid=$(get_session)
    if [ -z "$sid" ]; then
        echo "No active session. Use 'basil-cli new' to create one."
        return 1
    fi

    echo -e "${BLUE}Session: $sid${NC}"
    curl -s "$BASIL_URL/session/$sid" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(f\"Working dir: {d.get('working_dir', 'unknown')}\")
print(f\"Processing: {d.get('is_processing', False)}\")
print(f\"Pending permission: {d.get('has_pending_permission', False)}\")
"
}

cmd_send() {
    local text="$*"
    if [ -z "$text" ]; then
        echo "Usage: basil-cli send <message>"
        return 1
    fi

    local sid=$(get_session)
    if [ -z "$sid" ]; then
        echo "No active session. Use 'basil-cli new' first."
        return 1
    fi

    # Send message
    echo "$text" > /tmp/basil_msg.json.tmp
    python3 -c "import json; print(json.dumps({'text': open('/tmp/basil_msg.json.tmp').read().strip()}))" > /tmp/basil_msg.json

    local resp=$(curl -s -X POST "$BASIL_URL/chat" \
        -H "Content-Type: application/json" \
        -H "X-Session: $sid" \
        --data-binary @/tmp/basil_msg.json)

    local status=$(echo "$resp" | python3 -c "import sys,json; print(json.load(sys.stdin).get('status', 'error'))" 2>/dev/null)

    if [ "$status" != "processing" ]; then
        echo -e "${RED}Error: $resp${NC}"
        return 1
    fi

    # Get response blocks
    echo -e "${BLUE}Claude:${NC}"
    while true; do
        local block=$(curl -s "$BASIL_URL/chat/next?timeout=30" -H "X-Session: $sid")

        local btype=$(echo "$block" | python3 -c "import sys,json; print(json.load(sys.stdin).get('type', 'text'))" 2>/dev/null)
        local content=$(echo "$block" | python3 -c "import sys,json; print(json.load(sys.stdin).get('content', ''))" 2>/dev/null)
        local more=$(echo "$block" | python3 -c "import sys,json; print(json.load(sys.stdin).get('more', False))" 2>/dev/null)

        if [ "$btype" = "timeout" ]; then
            if [ "$more" = "True" ]; then
                continue
            else
                break
            fi
        elif [ "$btype" = "permission" ]; then
            local pid=$(echo "$block" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('permission_id') or d.get('metadata',{}).get('permission_id',''))" 2>/dev/null)
            local tool=$(echo "$block" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('tool') or d.get('metadata',{}).get('tool',''))" 2>/dev/null)
            local desc=$(echo "$block" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('description') or d.get('metadata',{}).get('description',''))" 2>/dev/null)

            echo ""
            echo -e "${YELLOW}╔══════════════════════════════════════╗${NC}"
            echo -e "${YELLOW}║       PERMISSION REQUIRED            ║${NC}"
            echo -e "${YELLOW}╠══════════════════════════════════════╣${NC}"
            echo -e "${YELLOW}║${NC} Tool: ${BLUE}$tool${NC}"
            echo -e "${YELLOW}║${NC} Action: $desc"
            echo -e "${YELLOW}╚══════════════════════════════════════╝${NC}"
            echo ""
            read -p "Allow this action? [y/N] " answer

            local allow="false"
            [ "$answer" = "y" ] || [ "$answer" = "Y" ] && allow="true"

            local decide_resp=$(curl -s -X POST "$BASIL_URL/permission/$pid/decide" \
                -H "Content-Type: application/json" \
                -d "{\"allow\": $allow}")

            if [ "$allow" = "true" ]; then
                echo -e "${GREEN}Allowed${NC}"
            else
                echo -e "${RED}Denied${NC}"
            fi
            echo ""
        else
            echo "$content"
        fi

        [ "$more" = "False" ] && break
    done
    echo ""
}

cmd_chat() {
    local sid=$(get_session)
    if [ -z "$sid" ]; then
        echo "No active session. Creating one..."
        cmd_new
        sid=$(get_session)
    fi

    echo -e "${GREEN}Basil Chat${NC} (session: $sid)"
    echo "Type 'exit' to quit, 'stop' to interrupt"
    echo ""

    while true; do
        read -p "> " input
        [ "$input" = "exit" ] && break
        [ "$input" = "stop" ] && { cmd_stop; continue; }
        [ -z "$input" ] && continue

        cmd_send "$input"
    done
}

cmd_stop() {
    local sid=$(get_session)
    if [ -z "$sid" ]; then
        echo "No active session."
        return 1
    fi

    curl -s -X POST "$BASIL_URL/chat/stop" -H "X-Session: $sid"
    echo -e "${YELLOW}Stopped${NC}"
}

# Main
case "${1:-}" in
    new)     shift; cmd_new "$@" ;;
    list)    cmd_list ;;
    use)     shift; cmd_use "$@" ;;
    status)  cmd_status ;;
    send)    shift; cmd_send "$@" ;;
    chat)    cmd_chat ;;
    stop)    cmd_stop ;;
    help|-h|--help) show_help ;;
    *)
        if [ -n "$1" ]; then
            # If argument given, treat as send
            cmd_send "$@"
        else
            show_help
        fi
        ;;
esac
